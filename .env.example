# SePay Payment Lab — copy file này thành .env và điền thông tin của bạn
# Windows: copy .env.example .env
# Mac/Linux: cp .env.example .env

# demo | sandbox | live
# - demo: không cần API key, polling giả lập (mặc định khi SEPAY_API_KEY trống)
# - sandbox: SePay Test mode API
# - live: SePay production API
SEPAY_RUN_MODE=demo

# SePay API Key (tạo tại my.sepay.vn → Test mode → API Access)
SEPAY_API_KEY=

# VietQR + SePay account
BANK_ID=TPB
ACCOUNT_NO=00000000000
ACCOUNT_NAME=TEN CUA HANG DEMO
ACCOUNT_BANK_ID=

# Payment settings
PAYMENT_AMOUNT=10000
POLLING_INTERVAL_SECONDS=5
PAYMENT_TIMEOUT_SECONDS=300
